<file path="app/views/exercises/show.html.erb">
<%# 背景 %>
<div class="fixed inset-0 -z-10 overflow-hidden bg-background-dark">
  <div class="absolute top-[-10%] left-[-10%] w-[600px] h-[600px] bg-primary/10 blur-[100px] rounded-full"></div>
  <div class="absolute bottom-[-10%] right-[-10%] w-[600px] h-[600px] bg-primary/10 blur-[100px] rounded-full"></div>
</div>

<main class="min-h-screen flex flex-col items-center justify-start p-6 pb-48 w-full max-w-5xl mx-auto">

  <%# タイトル %>
<div class="text-center mb-10 mt-8">
  <div class="inline-flex items-center gap-2 mb-3 text-primary">
    <span class="material-symbols-outlined text-xl">spa</span>
    <span class="font-bold tracking-[0.2em] uppercase text-md">Exercise & Stretch</span>
  </div>
  <h1 class="text-2xl md:text-5xl font-black text-text-main tracking-tight whitespace-nowrap">
    <%= @exercise.name %>
  </h1>
</div>

  <%# 画像エリア %>
<div class="w-full bg-white/40 backdrop-blur-md rounded-[2.5rem] shadow-[0_20px_50px_rgba(0,0,0,0.08)] overflow-hidden mb-12 border-2 border-white/60">
  <div class="aspect-video bg-background-dark relative group">
    <% if @exercise.image.attached? %>
      <%= image_tag @exercise.image,
          class: "w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" %>
    <% end %>
  </div>
</div>

  <%# 健康TIPS表示%>
  <div class="w-full mb-12 p-6 bg-white/50 backdrop-blur-md border-l-4 border-primary rounded-2xl">
  <div class="inline-flex items-center gap-2 mb-3 px-3 py-1 bg-primary/20 rounded-full">
    <span class="material-symbols-outlined text-primary text-sm">lightbulb</span>
    <span class="text-primary text-sm font-black uppercase tracking-widest">健康Tips</span>
  </div>
  <p class="text-text-main text-lg leading-relaxed font-medium">
    <%= @health_tip %>
  </p>
</div>

  <%# 解説・効果 %>
  <div class="w-full space-y-8">

    <%# 手順（全幅） %>
    <div>
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 rounded-xl bg-primary/20 flex items-center justify-center text-primary border border-primary/30">
          <span class="material-symbols-outlined">format_list_numbered</span>
        </div>
        <h2 class="text-xl font-black text-text-main">やり方</h2>
      </div>

      <div class="p-6 bg-white/50 backdrop-blur-md rounded-3xl border-2 border-white/60 shadow-[inset_0_1px_1px_rgba(255,255,255,0.8),0_4px_16px_rgba(0,0,0,0.05)]">
        <div class="relative pl-3">
          <div class="absolute left-[0.85rem] top-3 bottom-3 w-0.5 bg-primary/20 rounded-full"></div>
          <div class="space-y-2">
            <% steps = @exercise.instructions.to_s.split("\n").reject(&:blank?) %>
            <% steps.each_with_index do |step, index| %>
              <div class="flex gap-4 items-start">
                <div class="flex-shrink-0 w-7 h-7 rounded-full bg-primary text-white flex items-center justify-center font-black text-sm shadow-lg shadow-primary/20 z-10 mt-1">
                  <%= index + 1 %>
                </div>
                <div class="text-text-main text-base md:text-xl leading-relaxed font-medium pt-0.5 flex-1">
                  <%= step %>
                </div>
              </div>
              <% unless index == steps.length - 1 %>
                <div class="border-t border-white/60 ml-11"></div>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <%# 効果・注意ポイント（横並び） %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <% if @exercise.benefits.present? %>
        <div class="p-8 bg-white/40 backdrop-blur-md border-2 border-white/60 rounded-[2rem] shadow-[inset_0_1px_1px_rgba(255,255,255,0.8),0_4px_16px_rgba(0,0,0,0.05)]">
          <h3 class="text-text-main font-black flex items-center gap-2 mb-5 text-lg">
            <span class="material-symbols-outlined text-primary">stars</span>
            期待できる効果
          </h3>
          <ul class="text-base text-text-secondary space-y-4 leading-relaxed font-medium">
            <% @exercise.benefits.split("\n").reject(&:blank?).each do |benefit| %>
              <li class="flex gap-3">
                <span class="text-primary font-bold">•</span>
                <%= benefit %>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="p-8 bg-white/40 backdrop-blur-md border-2 border-white/60 rounded-[2rem] shadow-[inset_0_1px_1px_rgba(255,255,255,0.8),0_4px_16px_rgba(0,0,0,0.05)]">
        <h3 class="text-text-main font-black flex items-center gap-2 mb-5 text-lg">
          <span class="material-symbols-outlined text-primary">info</span>
          注意ポイント
        </h3>
        <ul class="text-base text-text-secondary space-y-4 leading-relaxed font-medium">
          <li class="flex gap-3"><span class="text-primary font-bold">•</span>呼吸を止めずに、ゆっくり</li>
          <li class="flex gap-3"><span class="text-primary font-bold">•</span>痛みのない「気持ちいい」範囲で</li>
          <li class="flex gap-3"><span class="text-primary font-bold">•</span>ストレッチは1分を目安に</li>
        </ul>
      </div>

    </div>
  </div>
</main>

<%# フッターバー %>
<div class="fixed bottom-0 left-0 right-0 z-40 p-4 md:p-8">
  <div class="max-w-4xl mx-auto bg-white/60 backdrop-blur-3xl rounded-[2.5rem] shadow-[0_-8px_40px_rgba(0,0,0,0.08)] p-4 md:p-5 border-2 border-white/60">

    <%# タイマーバー（1行目） %>
    <div class="w-full px-1 md:px-2 mb-3"
         data-controller="exercise-timer"
         data-exercise-timer-duration-value="300">
      <div class="flex justify-between items-end mb-1.5">
        <span class="text-xs md:text-md font-black text-primary uppercase tracking-[0.1em] md:tracking-[0.2em]">Exercise Progress</span>
        <span class="text-xs md:text-md font-bold text-text-secondary italic">目標時間　5分</span>
      </div>
      <div class="w-full h-3 bg-primary/10 rounded-full overflow-hidden border border-primary/20">
        <div class="h-full bg-primary rounded-full relative transition-all duration-1000 ease-linear"
             data-exercise-timer-target="bar"
             style="width: 100%;">
          <div class="absolute right-0 top-1/2 -translate-y-1/2 w-3 h-3 bg-white rounded-full shadow-[0_0_8px_rgba(106,155,118,0.8)] animate-pulse"></div>
        </div>
      </div>
    </div>

    <%# ボタン群（2行目） %>
    <div class="flex items-center gap-2 md:gap-4">
      <%= link_to root_path(reopen_modal: true, sitting_session_id: params[:sitting_session_id]),
          data: { turbo: false },
          class: "flex-1 md:flex-none px-4 md:px-8 h-12 md:h-14 rounded-2xl bg-primary/20 hover:bg-primary/30 text-text-main font-bold transition-all border-2 border-primary/30 hover:border-primary/50 flex items-center justify-center gap-2 active:scale-95 group whitespace-nowrap" do %>
        <span class="material-symbols-outlined text-primary text-xl group-hover:rotate-12 transition-transform">refresh</span>
        <span class="text-sm md:text-base">他の運動</span>
      <% end %>

      <%= button_to activity_logs_path(activity_log: { exercise_id: @exercise.id, sitting_session_id: params[:sitting_session_id] }),
          method: :post,
          class: "flex-[2] md:flex-none px-5 md:px-12 h-12 md:h-14 rounded-2xl bg-primary hover:bg-primary-hover text-white font-black transition-all shadow-xl shadow-primary/30 flex items-center justify-center gap-2 active:scale-95 group text-sm md:text-base whitespace-nowrap w-full" do %>
        <span class="material-symbols-outlined text-xl group-hover:scale-110 transition-transform">check_circle</span>
        <span>完了して戻る</span>
      <% end %>
    </div>

  </div>
</div>
</file>

<file path="app/controllers/sitting_sessions_controller.rb">
class SittingSessionsController < ApplicationController
  before_action :authenticate_user!

  def new
  end

  def create
    minutes = params.dig(:sitting_session, :duration).to_i
    @sitting_session = current_user.sitting_sessions.build(
      duration: minutes * 60, # 秒に変換
      status: :active
    )

    if @sitting_session.save

      # タイマー終了時に通知jobを予約する
      SendNotificationJob.set(wait_until: @sitting_session.notify_at)
                          .perform_later(@sitting_session.id)

      # テンプレートエラーが出るなら以下を追記
      head :no_content
    end
  end

  def finish_current
    @sitting_session = current_user.sitting_sessions.active.last
    return head :not_found unless @sitting_session

    # 休憩するで早期に終了したらdurationを更新
    @sitting_session.update(duration: (Time.current - @sitting_session.start_at).to_i)

    # ダメージを計算
    current_user.take_damage(@sitting_session.duration)

    # 休憩するボタンで終了した時に通知を送らないようにする
    @sitting_session.completed!

    # N+1を防ぐために一回のアクセスで3つの画像を取得
    @exercises = Exercise.order("RANDOM()").limit(3).includes(image_attachment: :blob)
    respond_to do |format|
      format.turbo_stream
    end
  end

  def subscribe
    auth_key = params[:subscription][:keys]

    if current_user.update(
      endpoint: params[:subscription][:endpoint],
      p256dh: auth_key[:p256dh],
      auth: auth_key[:auth]
    )
      head :ok
    else
      head :unprocessable_entity
    end
  end

  private

  def session_params
    params.require(:sitting_session).permit(:duration, :start_at)
  end
end
