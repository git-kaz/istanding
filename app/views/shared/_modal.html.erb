<%# app/views/shared/_modal.html.erb %>
<div class="fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center z-50 p-4 animate-in fade-in duration-300">
  <div class="bg-white/90 backdrop-blur-xl border-2 border-white/60 shadow-[0_20px_60px_rgba(0,0,0,0.15)] rounded-[2rem] md:rounded-[3rem] max-w-6xl w-full p-6 md:p-12 transform animate-in zoom-in-95 duration-300 max-h-[90vh] overflow-y-auto">

    <div class="text-center mb-6 md:mb-10">
      <span class="inline-block px-4 py-1.5 bg-primary/20 text-primary text-sm font-bold tracking-widest rounded-full border border-primary/30 mb-3">COMPLETE</span>
      <h3 class="text-2xl md:text-4xl font-black text-text-main tracking-tight">お疲れさまです！</h3>
      <p class="text-text-secondary mt-2 text-sm md:text-lg font-medium">少し体を動かして、リフレッシュしましょう🎵</p>
    </div>

    <%# 3つ横並びのグリッド %>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
      <% @exercises.each do |exercise| %>
        <%= link_to exercise_path(exercise, reopen_modal: true, sitting_session_id: sitting_session_id),
            class: "group relative block overflow-hidden rounded-xl md:rounded-[2rem] border-2 border-white/50 hover:border-primary/60 shadow-[inset_0_1px_1px_rgba(255,255,255,0.8),0_4px_16px_rgba(0,0,0,0.08)] hover:shadow-[0_8px_32px_rgba(106,155,118,0.25)] transition-all duration-500 active:scale-95" do %>

          <%# 画像エリア %>
          <div class="aspect-[16/9] md:aspect-[4/5] relative">
            <% if exercise.image.attached? %>
              <%= image_tag exercise.image,
                  class: "w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" %>
            <% else %>
              <div class="w-full h-full bg-slate-100 flex items-center justify-center text-slate-400 text-xs">No Image</div>
            <% end %>

            <%# オーバーレイ %>
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-2 md:p-6">
              <div class="translate-y-2 group-hover:translate-y-0 transition-transform duration-500">
                <div class="text-white font-black text-md md:text-lg leading-tight"><%= exercise.name %></div>
                <div class="mt-1 md:mt-2 hidden md:flex items-center text-primary-light text-xs font-bold opacity-0 group-hover:opacity-100 transition-opacity duration-500">
                  START NOW
                </div>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    
    <div class="text-center mt-6 md:mt-10">
      <button
          type="button"
          class="px-6 py-2.5 text-sm font-bold text-text-secondary hover:text-primary transition-colors cursor-pointer tracking-widest bg-white/30 backdrop-blur-sm border border-white/60 rounded-full shadow-[inset_0_1px_1px_rgba(255,255,255,0.8)] hover:bg-white/50 hover:border-white"
          data-action="click->timer#closeModal">
        今はスキップして戻る →
      </button>
    </div>
  </div>
</div>
