 <%# HPバー %>
<div class="mb-6">
    <div class="flex justify-between items-center mb-2">
        <h3 class="text-lg font-black text-text-secondary uppercase tracking-[0.2em]">ライフゲージ</h3>
        <span class="text-lg font-black text-text-main"><%= current_user.hp %> / 100</span>
    </div>
    <%# 5段階メモリ付きゲージ %>
    <div class="relative h-6 w-full bg-border-light/40 rounded-full overflow-hidden border border-white/50">
        <div class="h-full rounded-full transition-all duration-[1500ms] ease-out"
            style="width: <%= current_user.hp %>%; background-color: <%= hp_color(current_user.hp) %>;">
        </div>

        <%# 5段階のメモリ %>    
        <div class="absolute inset-0 flex pointer-events-none">
            <div class="flex-1 border-r-2 border-white/60"></div>
            <div class="flex-1 border-r-2 border-white/60"></div>
            <div class="flex-1 border-r-2 border-white/60"></div>
            <div class="flex-1 border-r-2 border-white/60"></div>
            <div class="flex-1"></div>
        </div>
    </div>
</div>