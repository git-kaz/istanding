<%= form_with model: [:admin, exercise], class: "flex flex-col gap-6" do |f| %>
  <%= render "devise/shared/error_messages", resource: exercise if exercise.errors.any? %>

  <div>
    <label class="text-sm font-bold mb-1 block">運動名</label>
    <%= f.text_field :name,
        placeholder: "例：肩甲骨ストレッチ",
        class: "w-full h-12 px-4 rounded-lg border border-border-light bg-input-bg-light focus:border-primary focus:ring-primary text-base" %>
  </div>

  <div>
    <label class="text-sm font-bold mb-1 block">カテゴリ</label>
    <%= f.select :category,
        Exercise.categories.keys.map { |k| [k, k] },
        { include_blank: "選択してください" },
        class: "w-full h-12 px-4 rounded-lg border border-border-light bg-input-bg-light focus:border-primary text-base" %>
  </div>

  <div>
    <label class="text-sm font-bold mb-1 block">手順</label>
    <%= f.text_area :instructions,
        rows: 5,
        placeholder: "運動の手順や説明を入力してください",
        class: "w-full px-4 py-3 rounded-lg border border-border-light bg-input-bg-light focus:border-primary text-base resize-none" %>
  </div>

  <div>
    <label class="text-sm font-bold mb-1 block">効果</label>
    <%= f.text_area :benefits,
      rows: 3,
      placeholder: "例：肩こりの解消・血流改善",
      class: "w-full px-4 py-3 rounded-lg border border-border-light bg-input-bg-light focus:border-primary text-base resize-none" %>
  </div>

  <div class="flex items-center gap-3 p-4 bg-background-light rounded-2xl border border-border-light">
    <%= f.check_box :active, class: "w-5 h-5 rounded text-primary focus:ring-primary" %>
    <%= f.label :active, "この運動をアプリに表示する", class: "text-sm font-bold text-text-main" %>
  </div>

  <div>
    <label class="text-sm font-bold mb-1 block">画像</label>
    <%= f.file_field :image,
        accept: "image/*",
        class: "w-full text-sm text-text-secondary file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:font-bold file:bg-primary/10 file:text-primary hover:file:bg-primary/20" %>
    <% if exercise.image.attached? %>
      <div class="mt-3">
        <p class="text-xs text-text-secondary mb-1">現在の画像</p>
        <%= image_tag exercise.image, width: 200, crop: :fill, class: "rounded-lg" %>
      </div>
    <% end %>
  </div>

  <%= f.submit exercise.new_record? ? "追加する" : "更新する",
      class: "w-full h-12 rounded-lg bg-primary text-white font-bold hover:bg-primary-hover transition cursor-pointer" %>
<% end %>
