<div class="max-w-4xl mx-auto px-6 py-12">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-black">運動管理</h1>
    <%= link_to "＋ 新規追加", new_admin_exercise_path,
        class: "px-5 py-2.5 rounded-full bg-primary text-white text-sm font-bold hover:bg-primary-hover transition" %>
  </div>

  <div class="bg-white rounded-2xl border border-border-light overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b border-border-light">
        <tr>
          <th class="text-left px-6 py-3 font-bold text-text-secondary">名前</th>
          <th class="text-left px-6 py-3 font-bold text-text-secondary">カテゴリ</th>
          <th class="text-left px-6 py-3 font-bold text-text-secondary">操作</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border-light">
        <% @exercises.each do |exercise| %>
          <tr class="hover:bg-gray-50 transition">
            <td class="px-6 py-4 font-bold"><%= exercise.name %></td>
            <td class="px-6 py-4 text-text-secondary"><%= exercise.category %></td>
            <td class="px-6 py-4 flex items-center gap-3">
              <%= link_to "編集", edit_admin_exercise_path(exercise),
                  class: "text-primary font-bold hover:underline" %>
              <%= button_to "削除", admin_exercise_path(exercise),
                  method: :delete,
                  data: { turbo_confirm: "本当に削除しますか？" },
                  class: "text-red-400 font-bold hover:underline cursor-pointer" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
