<div class="min-h-screen bg-background-dark p-4 md:p-6 overflow-x-hidden"
    data-controller="notification timer"
    data-notification-public-key-value="<%= Rails.application.credentials.dig(:webpush, :public_key) %>"
    data-timer-notify-at-value="<%= @active_session&.notify_at&.iso8601 %>"
    data-timer-audio-url-value="/chime.mp3">

  <%# メインコンテナ: lg:flex-row で横並び、items-start で上揃えに調整 %>
  <div class="max-w-6xl mx-auto flex flex-col lg:flex-row items-center lg:items-start justify-center gap-8 lg:gap-12 transition-all duration-500">

    <%# --- 左カラム: タイマーエリア --- %>
    <div class="flex flex-col items-center px-4 py-10 md:px-8 md:py-12 rounded-[4rem]
                bg-input-bg-light/80 backdrop-blur-3xl
                border border-white/40
                shadow-[0_20px_50px_rgba(0,0,0,0.05)] ring-1 ring-text-main/5
                w-full max-w-lg shrink-0">

      <%# タイマー円 %>
      <div class="relative flex items-center justify-center w-72 h-72 md:w-80 md:h-80 mb-8">
        <svg viewBox="0 0 300 300" class="w-full h-full transform -rotate-270 -scale-x-100">
          <circle cx="150" cy="150" r="135"
                  stroke="currentColor" stroke-width="2" fill="transparent"
                  class="text-border-light opacity-50" />
          <circle cx="150" cy="150" r="135"
                  stroke="currentColor" stroke-width="6" fill="transparent"
                  data-timer-target="circle"
                  class="text-primary transition-all duration-1000 ease-linear"
                  style="stroke-linecap: round;" />
        </svg>

        <div class="absolute flex flex-col items-center justify-center">
          <div class="text-7xl font-extralight tracking-tighter text-text-main" data-timer-target="display">
            00:00
          </div>
        </div>
      </div>

      <%# 時間選択ボタン（セグメントコントロール） %>
      <div class="w-full mb-6">
        <div class="flex bg-primary/20 rounded-3xl p-1 gap-1">
          <% SittingSession::SETTING_DURATIONS.each_with_index do |minutes, index| %>
            <button type="button"
              class="flex-1 py-2 rounded-3xl text-lg font-bold transition-all cursor-pointer duration-button whitespace-nowrap text-text-secondary hover:text-text-main"
                data-action="click->timer#setTime"
                data-timer-minutes-param="<%= minutes %>">
              <%= minutes %><span class="text-xs ml-0.5 font-medium">分</span>
            </button>
          <% end %>
        </div>
      </div>

      <div class="flex items-center justify-center gap-2 mb-4 transition-all duration-300 hidden" 
           data-timer-target="errorMessage">
        <span class="material-symbols-outlined text-red-500 text-xl font-bold">error</span>
        <p class="text-red-500 text-sm font-bold tracking-tight">時間を選択してください</p>
      </div>

      <%# スタート・休憩するボタン %>
      <div class="flex flex-col items-center space-y-4 w-full">
        <button type="button"
          class="bg-primary text-white py-5 px-12 rounded-[1.5rem] text-xl font-black tracking-widest shadow-lg hover:bg-primary-hover transition-all active:scale-[0.96] cursor-pointer w-full max-w-[240px]"
          data-action="click->timer#start"
          data-timer-target="startButton">
          スタート
        </button>
        
        <button type="button"
          data-timer-target="runningButton"
          data-action="click->timer#finish"
          class="py-4 px-12 rounded-2xl text-lg font-bold tracking-widest bg-primary/20 text-text-main border border-primary/50 shadow-lg hover:bg-primary/30 transition-all active:scale-95 cursor-pointer hidden w-full max-w-[240px]">
          休憩する
        </button>

        <button type="button"
          data-timer-target="runningButton"
          data-action="click->timer#reset"
          class="py-4 px-12 rounded-2xl text-lg font-bold tracking-widest bg-white text-primary ring-2 ring-primary shadow-lg hover:bg-primary/10 transition-all active:scale-95 cursor-pointer hidden w-full max-w-[240px]">
          リセット
        </button>
      </div>
      <%# 通知音トグル %>
      <div class="flex items-center space-x-2 mt-4">
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="checkbox" 
                 checked 
                 data-timer-target="mute" 
                 class="sr-only peer">
          <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
          <span class="ml-3 text-sm font-medium text-gray-900">終了時に通知音を鳴らす</span>
        </label>
      </div>
    </div> <%# タイマーカードの閉じタグ %>

    <%# --- 右カラム: 統計・HPエリア --- %>
    <div class="w-full max-w-lg space-y-6 flex-grow">
      <%# HPゲージカード全体 %>
      <div class="bg-white/60 backdrop-blur-xl px-8 py-9 rounded-[3rem] border border-white shadow-sm flex flex-col items-center">
        
        <%# HPゲージ本体 %>
        <div id="hp_card" class="w-full mb-8">
          <%= render "shared/hp_card" %>
        </div>

        <%# アクションボタン %>
        <div class="w-full mb-8">
          <%= button_to random_exercises_path, 
              method: :post,
              class: "group w-full py-4 rounded-2xl bg-white border-2 border-primary/30 text-primary font-black tracking-widest
                     flex items-center justify-center gap-2 shadow-sm
                     transition-all hover:bg-primary hover:text-white hover:border-primary hover:scale-[1.02] active:scale-[0.98] cursor-pointer" do %>
            <span class="material-symbols-outlined text-2xl group-hover:animate-bounce">fitness_center</span>
            <span>とりあえず運動して回復</span>
          <% end %>
        </div>

        <%# ステータス説明 %>
        <div class="w-full space-y-4 mb-8">
          <div class="flex items-center gap-4 px-4 py-3 bg-red-50/50 rounded-2xl border border-red-100">
            <span class="material-symbols-outlined text-red-500 text-3xl">heart_broken</span>
            <div class="flex flex-col">
              <span class="text-xs font-black text-red-600 uppercase tracking-tighter">Damage</span>
              <span class="text-sm font-bold text-red-800">座りすぎでHPが減少します</span>
            </div>
          </div>

          <div class="flex items-center gap-4 px-4 py-3 bg-primary/10 rounded-2xl border border-primary/20">
            <span class="material-symbols-outlined text-primary text-3xl">ecg_heart</span>
            <div class="flex flex-col">
              <span class="text-xs font-black text-primary uppercase tracking-tighter">Recovery</span>
              <span class="text-sm font-bold text-text-main">運動を行うとHPが回復します</span>
            </div>
          </div>
        </div>

        <%# 区切り線 %>
        <div class="w-full border-t border-white/60 mb-8"></div>

        <%# 統計データ %>
        <div class="grid grid-cols-2 gap-4 w-full">
          <div class="bg-white/40 rounded-2xl p-4 border border-white/60 shadow-lg text-center">
            <p class="text-xs font-black text-text-secondary uppercase tracking-widest mb-1">座位時間</p>
            <div class="flex items-baseline justify-center gap-1">
              <span class="text-3xl font-black text-text-main"><%= (@total_seconds / 3600.0).round(1) %></span>
              <span class="text-xs font-bold text-text-secondary">h</span>
            </div>
          </div>
          <div class="bg-white/40 rounded-2xl p-4 border border-white/60 shadow-lg text-center">
            <p class="text-xs font-black text-text-secondary uppercase tracking-widest mb-1">運動回数</p>
            <div class="flex items-baseline justify-center gap-1">
              <span class="text-3xl font-black text-text-main"><%= @exercise_count %></span>
              <span class="text-xs font-bold text-text-secondary">Sets</span>
            </div>
          </div>
        </div>
      </div>
    </div> <%# 右カラムの閉じタグ %>

  </div> <%# メインコンテナの閉じタグ %>

  <div id="modal_container">
    <% if params[:reopen_modal] == "true" && @exercises.present? %>
      <%= render partial: "shared/modal", locals: { exercises: @exercises, sitting_session_id: params[:sitting_session_id] } %>
    <% end %>
  </div>
</div>