<div class="min-h-screen bg-background-dark p-4 md:p-8 overflow-x-hidden"
    data-controller="notification timer"
    data-notification-public-key-value="<%= Rails.application.credentials.dig(:webpush, :public_key) %>">

  <div class="max-w-6xl mx-auto flex flex-col lg:flex-row items-center lg:items-center justify-center gap-10 lg:gap-20 transition-all duration-500">
    
    <div class="flex flex-col items-center p-10 md:p-14 rounded-[4rem]
                bg-input-bg-light/80 backdrop-blur-3xl 
                border border-white/40
                shadow-[0_20px_50px_rgba(0,0,0,0.05)] ring-1 ring-text-main/5 
                w-full max-w-md shrink-0">

      <div class="relative flex items-center justify-center w-64 h-64 md:w-72 md:h-72">
        <svg viewBox="0 0 300 300" class="w-full h-full transform -rotate-270 -scale-x-100">
          <circle cx="150" cy="150" r="135"
                  stroke="currentColor" stroke-width="2" fill="transparent"
                  class="text-border-light opacity-50" />
          <circle cx="150" cy="150" r="135"
                  stroke="currentColor" stroke-width="6" fill="transparent"
                  data-timer-target="circle"
                  class="text-primary transition-all duration-1000 ease-linear"
                  style="stroke-linecap: round;" />
        </svg>

        <div class="absolute flex flex-col items-center justify-center">
          <div class="text-6xl font-extralight tracking-tighter text-text-main" data-timer-target="display">
            00:00
          </div>
        </div>
      </div>

      <%= form_with model: SittingSession.new, id: "timer-form" do |f| %>
      <div class="mt-8 w-full space-y-6">
        <div class="flex flex-wrap gap-2 justify-center">
          <% SittingSession::SETTING_DURATIONS.each do |minutes| %>
            <button type="button" class="flex-1 min-w-[60px] py-2.5 bg-white/40 border border-border-light hover:border-primary rounded-xl text-text-secondary font-semibold transition-all active:scale-90"
                    data-action="click->timer#setTime" data-timer-minutes-param="<%= minutes %>">
              <%= minutes %><span class="text-[9px] ml-0.5 opacity-60">min</span>
            </button>
          <% end %>
        </div>

        <%= f.hidden_field :duration, data: { timer_target: "durationInput" } %>

        <div class="space-y-4">
          <%= f.submit "スタート",class: "bg-primary text-text-main py-4 w-full rounded-[1.5rem] font-bold tracking-widest shadow-lg hover:bg-primary-hover transition-all active:scale-[0.96] cursor-pointer",
          data: { action: "click->timer#start" } %>
      
        <button type="button" data-action="click->timer#finish" class="w-full py-4 rounded-xl font-bold text-xs tracking-widest bg-background-light text-text-secondary border border-border-light hover:bg-white transition-all active:scale-95 cursor-pointer">
          休憩する
        </button>
          
        </div>
      </div>
      <% end %>
    </div>

    <div class="w-full max-w-md lg:max-w-lg space-y-8">
      
      <div class="bg-white/60 backdrop-blur-xl p-8 rounded-[3rem] border border-white shadow-sm transition-transform hover:scale-[1.02]">
        <div class="flex justify-between items-end mb-6">
          <div>
            <h3 class="text-[11px] font-black text-text-secondary uppercase tracking-[0.2em] mb-2">本日の座位時間</h3>
            <p class="text-4xl font-black text-text-main tracking-tight italic">
              <%= (@total_seconds / 3600.0).round(1) %><span class="text-lg font-bold text-text-secondary not-italic ml-1">/ 11時間</span>
            </p>
          </div>
          <div class="bg-primary/20 px-4 py-1 rounded-full border border-primary/30">
            <span class="text-lg font-black text-primary"><%= @percentage %>%</span>
          </div>
        </div>
        
        <div class="h-6 w-full bg-border-light/40 rounded-full overflow-hidden p-1.5 border border-white/50">
          <div class="h-full bg-primary rounded-full transition-all duration-[1500ms] ease-out shadow-[0_0_15px_rgba(175,195,177,0.6)]"
               style="width: <%= @percentage %>%">
          </div>
        </div>
        
        <div class="mt-6 flex items-start gap-3 bg-white/40 p-4 rounded-2xl border border-white/60">
          <span class="material-symbols-outlined text-primary font-bold">warning</span>
          <p class="text-[11px] text-text-secondary leading-relaxed font-medium">
            11時間を超えると健康リスクが大幅に上昇します。<br>こまめな運動で血流を改善しましょう。
          </p>
        </div>
      </div>

      <div class="bg-white/60 backdrop-blur-xl p-8 rounded-[3rem] border border-white shadow-sm flex items-center justify-between group overflow-hidden relative">
        <div class="relative z-10 text-left">
          <h3 class="text-[11px] font-black text-text-secondary uppercase tracking-[0.2em] mb-1">運動した回数</h3>
          <p class="text-4xl font-black text-text-main tracking-tight">
            <%= @exercise_count %><span class="text-lg font-bold text-text-secondary ml-1 italic">Sets</span>
          </p>
        </div>
        
        <div class="relative z-10 w-16 h-16 bg-primary text-white rounded-[1.8rem] flex items-center justify-center shadow-lg shadow-primary/30 group-hover:rotate-12 transition-transform duration-500">
          <span class="material-symbols-outlined text-3xl font-bold">fitness_center</span>
        </div>
        
        <span class="material-symbols-outlined absolute -right-4 -bottom-4 text-8xl text-primary/5 -rotate-12 select-none">
          sprint
        </span>
      </div>

    </div>
   <div id="modal_container">
    <% if params[:reopen_modal] == "true" && @exercises.present? %>
      <%= render partial: "shared/modal", locals: { exercise: @exercises } %>
    <% end %>
   </div>
  </div>
</div>