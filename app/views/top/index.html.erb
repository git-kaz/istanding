<div class="min-h-screen bg-background-dark p-4 md:p-6 overflow-x-hidden"
    data-controller="notification timer"
    data-notification-public-key-value="<%= Rails.application.credentials.dig(:webpush, :public_key) %>">

  <div class="max-w-6xl mx-auto flex flex-col lg:flex-row items-center lg:items-center justify-center gap-8 lg:gap-16 transition-all duration-500">

    <%# タイマーカード %>
    <div class="flex flex-col items-center px-4 py-10 md:px-4 md:py-12 rounded-[4rem]
                bg-input-bg-light/80 backdrop-blur-3xl
                border border-white/40
                shadow-[0_20px_50px_rgba(0,0,0,0.05)] ring-1 ring-text-main/5
                w-full max-w-lg shrink-0">

      <%# タイマー円 %>
      <div class="relative flex items-center justify-center w-72 h-72 md:w-80 md:h-80">
        <svg viewBox="0 0 300 300" class="w-full h-full transform -rotate-270 -scale-x-100">
          <circle cx="150" cy="150" r="135"
                  stroke="currentColor" stroke-width="2" fill="transparent"
                  class="text-border-light opacity-50" />
          <circle cx="150" cy="150" r="135"
                  stroke="currentColor" stroke-width="6" fill="transparent"
                  data-timer-target="circle"
                  class="text-primary transition-all duration-1000 ease-linear"
                  style="stroke-linecap: round;" />
        </svg>

        <div class="absolute flex flex-col items-center justify-center">
          <div class="text-7xl font-extralight tracking-tighter text-text-main" data-timer-target="display">
            00:00
          </div>
        </div>
      </div>

      <%= form_with model: SittingSession.new, id: "timer-form" do |f| %>
      <div class="mt-8 w-full space-y-5">

        <%# 時間選択ボタン（セグメントコントロール） %>
        <div class="-mx-20 md:-mx-30">
          <div class="w-full flex bg-primary/20 rounded-3xl p-1 gap-1">
            <% SittingSession::SETTING_DURATIONS.each_with_index do |minutes, index| %>
              <button type="button"
                class="flex-1 py-2 rounded-3xl text-lg font-bold transition-all cursor-pointer duration-button whitespace-nowrap
                     <%= index == 0 ? 'bg-primary text-white shadow-md' : 'text-text-secondary hover:text-text-main' %>"
                  data-action="click->timer#setTime"
                  data-timer-minutes-param="<%= minutes %>">
                <%= minutes %><span class="text-xs ml-0.5 font-medium">分</span>
              </button>
            <% end %>
          </div>
        </div>

        <%= f.hidden_field :duration, data: { timer_target: "durationInput" } %>

        <%# スタート・休憩するボタン %>
        <div class="space-y-3 pt-1">
          <%= f.submit "スタート",
            class: "bg-primary text-white py-5 w-full rounded-[1.5rem] text-xl font-black tracking-widest shadow-lg hover:bg-primary-hover transition-all active:scale-[0.96] cursor-pointer",
            data: { action: "click->timer#start" } %>

          <button type="button"
            data-action="click->timer#finish"
            class="w-full py-4 rounded-2xl text-lg font-bold tracking-widest bg-primary/20 text-text-main border-primary/50 shadow-lg hover:bg-primary/30 hover:border-primary/50 transition-all active:scale-95 cursor-pointer">
            休憩する
          </button>
          
        </div>
      </div>
      <% end %>
      <div class="mt-4">
        <%= button_to "とりあえず運動する", random_exercises_path, 
            method: :post,
            class: "w-full py-4 text-lg font-bold tracking-widest text-primary transition-all hover:scale-110 cursor-pointer" %>
      </div>
      
    </div>

    <%# 右カラム: 統計エリア %>
    <div class="w-full max-w-lg space-y-6">

      <%# HPゲージカード %>
      <div class="bg-white/60 backdrop-blur-xl px-10 py-9 rounded-[3rem] border border-white shadow-sm">

        <div id="hp_card">
          <%= render "shared/hp_card" %>
        </div>
        <%# 説明バッジ %>
        <div class="flex justify-center gap-3 mb-6">
          <div class="px-3 py-1.5 bg-red-50 rounded-full border border-red-200">
            <span class="text-xs font-bold text-red-500">座りすぎでダメージ</span>
          </div>
          <div class="px-3 py-1.5 bg-primary/10 rounded-full border border-primary/20">
            <span class="text-xs font-bold text-primary">運動で回復</span>
          </div>
        </div>

        <%# 区切り線 %>
        <div class="border-t border-white/60 mb-6"></div>

        <%# 座位時間 + 運動回数 横並び %>
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-white/40 rounded-2xl p-4 border border-white/60">
            <p class="text-xs font-black text-text-secondary uppercase tracking-widest mb-2">座位時間</p>
            <p class="text-3xl font-black text-text-main">
              <%= (@total_seconds / 3600.0).round(1) %><span class="text-sm font-bold text-text-secondary ml-1">h</span>
            </p>
          </div>
          <div class="bg-white/40 rounded-2xl p-4 border border-white/60">
            <p class="text-xs font-black text-text-secondary uppercase tracking-widest mb-2">運動回数</p>
            <p class="text-3xl font-black text-text-main">
              <%= @exercise_count %><span class="text-sm font-bold text-text-secondary ml-1">Sets</span>
            </p>
          </div>
        </div>

      </div>

    </div>

    <div id="modal_container">
      <% if params[:reopen_modal] == "true" && @exercises.present? %>
        <%= render partial: "shared/modal", locals: { exercises: @exercises, sitting_session_id: params[:sitting_session_id] } %>
      <% end %>
    </div>
  </div>
</div>
