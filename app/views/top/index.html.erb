<div class="min-h-screen bg-background-dark p-4 md:p-6 overflow-x-hidden"
    data-controller="notification timer"
    data-notification-public-key-value="<%= Rails.application.credentials.dig(:webpush, :public_key) %>">

  <div class="max-w-6xl mx-auto flex flex-col lg:flex-row items-center lg:items-center justify-center gap-8 lg:gap-16 transition-all duration-500">
    
    <%# タイマーカード %>
    <div class="flex flex-col items-center px-10 py-10 md:px-14 md:py-12 rounded-[4rem]
                bg-input-bg-light/80 backdrop-blur-3xl 
                border border-white/40
                shadow-[0_20px_50px_rgba(0,0,0,0.05)] ring-1 ring-text-main/5 
                w-full max-w-lg shrink-0">

      <%# タイマー円 %>
      <div class="relative flex items-center justify-center w-72 h-72 md:w-80 md:h-80">
        <svg viewBox="0 0 300 300" class="w-full h-full transform -rotate-270 -scale-x-100">
          <circle cx="150" cy="150" r="135"
                  stroke="currentColor" stroke-width="2" fill="transparent"
                  class="text-border-light opacity-50" />
          <circle cx="150" cy="150" r="135"
                  stroke="currentColor" stroke-width="6" fill="transparent"
                  data-timer-target="circle"
                  class="text-primary transition-all duration-1000 ease-linear"
                  style="stroke-linecap: round;" />
        </svg>

        <div class="absolute flex flex-col items-center justify-center">
          <div class="text-7xl font-extralight tracking-tighter text-text-main" data-timer-target="display">
            00:00
          </div>
        </div>
      </div>

      <%= form_with model: SittingSession.new, id: "timer-form" do |f| %>
      <div class="mt-8 w-full space-y-5">

       <%# 時間選択ボタン %>
        <div class="flex flex-wrap gap-3 justify-center">
          <% SittingSession::SETTING_DURATIONS.each do |minutes| %>
            <button type="button"
                    class="flex-1 min-w-[96px] py-5 bg-white/40 border border-border-light hover:border-primary hover:bg-white rounded-2xl text-text-main text-2xl font-bold transition-all active:scale-90 cursor-pointer"
                    data-action="click->timer#setTime" data-timer-minutes-param="<%= minutes %>">
              <%= minutes %><span class="text-base ml-1 text-text-secondary font-medium">min</span>
            </button>
          <% end %>
        </div>

        <%= f.hidden_field :duration, data: { timer_target: "durationInput" } %>

        <%# スタート・休憩するボタン %>
        <div class="space-y-3 pt-1">
          <%= f.submit "スタート",
            class: "bg-primary text-white py-5 w-full rounded-[1.5rem] text-xl font-black tracking-widest shadow-lg hover:bg-primary-hover transition-all active:scale-[0.96] cursor-pointer",
            data: { action: "click->timer#start" } %>

          <button type="button"
            data-action="click->timer#finish"
            class="w-full py-4 rounded-2xl text-lg font-bold tracking-widest bg-primary/20 text-text-main border-primary/50 shadow-lg hover:bg-primary/30 hover:border-primary/50 transition-all active:scale-95 cursor-pointer">
            休憩する
          </button>
        </div>
      </div>
      <% end %>
    </div>

    <%# 右カラム: 統計エリア %>
    <div class="w-full max-w-lg space-y-6">
      
      <%# 本日の座位時間 %>
      <div class="bg-white/60 backdrop-blur-xl px-10 py-9 rounded-[3rem] border border-white shadow-sm transition-transform hover:scale-[1.02]">
        <div class="flex justify-between items-end mb-6">
          <div>
            <h3 class="text-lg font-black text-text-secondary uppercase tracking-[0.2em] mb-2">本日の座位時間</h3>
            <p class="text-5xl font-black text-text-main tracking-tight italic">
              <%= (@total_seconds / 3600.0).round(1) %><span class="text-xl font-bold text-text-secondary not-italic ml-2">/ 11時間</span>
            </p>
          </div>
          <div class="bg-primary/20 px-5 py-2 rounded-full border border-primary/30">
            <span class="text-xl font-black text-primary"><%= @percentage %>%</span>
          </div>
        </div>
        
        <div class="h-6 w-full bg-border-light/40 rounded-full overflow-hidden p-1.5 border border-white/50">
          <div class="h-full bg-primary rounded-full transition-all duration-[1500ms] ease-out shadow-[0_0_15px_rgba(175,195,177,0.6)]"
               style="width: <%= @percentage %>%">
          </div>
        </div>
        
        <div class="mt-6 flex items-start gap-3 bg-white/40  rounded-2xl border border-white/60">
          <span class="material-symbols-outlined text-primary font-bold">warning</span>
          <p class="text-base text-text-secondary leading-relaxed font-medium">
            11時間を超えると健康リスクが大幅に上昇します。<br>こまめな運動で血流を改善しましょう。
          </p>
        </div>
      </div>

      <%# 運動した回数 %>
      <div class="bg-white/60 backdrop-blur-xl px-10 py-9 rounded-[3rem] border border-white shadow-sm flex items-center justify-between group overflow-hidden relative">
        <div class="relative z-10 text-left">
          <h3 class="text-lg font-black text-text-secondary uppercase tracking-[0.2em] mb-2">運動した回数</h3>
          <p class="text-5xl font-black text-text-main tracking-tight">
            <%= @exercise_count %><span class="text-xl font-bold text-text-secondary ml-2 italic">Sets</span>
          </p>
        </div>
        
        <div class="relative z-10 w-20 h-20 bg-primary text-white rounded-[1.8rem] flex items-center justify-center shadow-lg shadow-primary/30 group-hover:rotate-12 transition-transform duration-500">
          <span class="material-symbols-outlined text-4xl font-bold">fitness_center</span>
        </div>
        
        <span class="material-symbols-outlined absolute -right-4 -bottom-4 text-8xl text-primary/5 -rotate-12 select-none">
          sprint
        </span>
      </div>

    </div>

    <div id="modal_container">
      <% if params[:reopen_modal] == "true" && @exercises.present? %>
        <%= render partial: "shared/modal", locals: { exercise: @exercises } %>
      <% end %>
    </div>
  </div>
</div>
