<div class="flex min-h-screen items-center justify-center bg-background-light px-4 py-10">
  <div class="w-full max-w-[480px] bg-white rounded-2xl shadow-xl border border-border-light overflow-hidden z-10">

    <div class="px-8 pt-10 pb-4 text-center">
      <%# アイコンを「鍵」に変更し、新規登録画面と同じスタイルを適用 %>
      <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-6 text-primary">
        <span class="material-symbols-outlined md-20">lock_reset</span>
      </div>

      <h1 class="text-2xl md:text-3xl font-bold mb-2">
        パスワードをお忘れですか？
      </h1>
      <p class="text-sm text-text-secondary mt-2">
        ご登録のメールアドレスを入力してください。<br>再設定用のリンクをお送りします。
      </p>
    </div>

    <%# フラッシュメッセージ表示 %>
    <% if notice %>
      <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mx-4 mt-4 text-sm" role="alert">
        <%= notice %>
      </div>
    <% end %>
    
    <% if alert %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mx-4 mt-4 text-sm" role="alert">
        <%= alert %>
      </div>
    <% end %>
     
    <div class="p-8 pt-4">

      <%# 新規登録画面と共通の入力フォームスタイル %>
      <% input_class = "form-input w-full rounded-lg border border-border-light
                        bg-input-bg-light h-12 px-4 text-base
                        focus:border-primary focus:ring-primary" %>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name),
                   html: { method: :post, class: "flex flex-col gap-5" }) do |f| %>
        
        <%# Devise標準のエラーメッセージ %>
        <%= render "devise/shared/error_messages", resource: resource %>
       
        <div>
          <label class="text-sm font-bold">メールアドレス</label>
          <%= f.email_field :email,
                autofocus: true,
                autocomplete: "email",
                placeholder: "your@email.com",
                class: input_class %>
        </div>

        <%= f.submit "再設定メールを送信する",
              class: "mt-4 w-full h-12 rounded-lg bg-primary
                      hover:bg-primary-hover text-white font-bold
                      transition shadow-md cursor-pointer" %>

        <div class="text-center text-sm mt-2">
          <%= render "devise/shared/links" %>
        </div>

      <% end %>
    </div>
  </div>
</div>